set -eo pipefail

# shellcheck source=lib/utils.sh
source "$(dirname "$0")/../lib/utils.sh"

download_lean() {
  local install_type=$1
  local version=$2
  local download_path=$3

  check_dependencies

  if [ "$install_type" != "version" ]; then
    fail "asdf-lean supports release installs only"
  fi

  # Resolve "latest" to a concrete version
  if [ "$version" = "latest" ]; then
    version=$("$(dirname "$0")/latest-stable")
  fi

  local platform
  local arch_suffix

  platform=$(get_platform)
  arch_suffix=$(get_arch_suffix)

  local filename="lean-${version}-${platform}${arch_suffix}.tar.zst"
  local download_url="https://github.com/leanprover/lean4/releases/download/v${version}/${filename}"
  local archive_path="${download_path}/${filename}"

  echo "∗ Downloading lean ${version}..."
  mkdir -p "$download_path"
  curl --fail --silent --location --output "$archive_path" "$download_url" || fail "Could not download $download_url"

  echo "∗ Extracting..."
  zstd -d <"$archive_path" | tar --strip-components=1 -xf - -C "$download_path" || fail "Could not extract $archive_path"
  rm -f "$archive_path"
}

download_lean "$ASDF_INSTALL_TYPE" "$ASDF_INSTALL_VERSION" "$ASDF_DOWNLOAD_PATH"
