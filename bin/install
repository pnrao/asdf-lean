set -eo pipefail

# shellcheck source=lib/utils.sh
source "$(dirname "$0")/../lib/utils.sh"

install_lean() {
  local install_type=$1
  local install_path=$3
  local download_path=$4

  if [ "$install_type" != "version" ]; then
    fail "asdf-lean supports release installs only"
  fi

  [ -d "$download_path" ] || fail "Download path not found: $download_path"

  cp -r "$download_path"/. "$install_path/"
  echo "The installation was successful!"
}

install_lean "$ASDF_INSTALL_TYPE" "$ASDF_INSTALL_VERSION" "$ASDF_INSTALL_PATH" "$ASDF_DOWNLOAD_PATH"
