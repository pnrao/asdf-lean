set -eo pipefail

fail() {
  echo -e "\e[31mFail:\e[m $* 😭"
  exit 1
}

download_lean() {
  local install_type=$1
  local version=$2
  local download_path=$3

  if [ "$install_type" != "version" ]; then
    fail "asdf-lean supports release installs only"
  fi

  local platform
  local arch_suffix

  case "$OSTYPE" in
    darwin*) platform="darwin" ;;
    linux*)  platform="linux" ;;
    *)       fail "Unsupported platform: $OSTYPE" ;;
  esac

  case "$(uname -m)" in
    x86_64)           arch_suffix="" ;;
    arm64 | aarch64)  arch_suffix="_aarch64" ;;
    *)                fail "Unsupported architecture: $(uname -m)" ;;
  esac

  local filename="lean-${version}-${platform}${arch_suffix}.tar.zst"
  local download_url="https://github.com/leanprover/lean4/releases/download/v${version}/${filename}"
  local archive_path="${download_path}/${filename}"

  echo "∗ Downloading lean ${version}..."
  mkdir -p "$download_path"
  curl --silent --location --output "$archive_path" "$download_url" || fail "Could not download $download_url"

  echo "∗ Extracting..."
  tar --strip-components=1 -xf "$archive_path" -C "$download_path" || fail "Could not extract $archive_path"
  rm -f "$archive_path"
}

download_lean "$ASDF_INSTALL_TYPE" "$ASDF_INSTALL_VERSION" "$ASDF_DOWNLOAD_PATH"
