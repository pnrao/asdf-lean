set -eo pipefail

cmd="curl --silent --location"

if [ -n "$GITHUB_API_TOKEN" ]; then
  cmd="$cmd --header 'Authorization: token $GITHUB_API_TOKEN'"
fi

sort_versions() {
  sed 'h; s/[+-]/./g; s/.p\([[:digit:]]\)/.z\1/; s/$/.z/; G; s/\n/ /' |
    LC_ALL=C sort -t. -k 1,1 -k 2,2n -k 3,3n -k 4,4n -k 5,5n | awk '{print $2}'
}

all_versions=""
page=1
while true; do
  response=$(eval "$cmd 'https://api.github.com/repos/leanprover/lean4/releases?per_page=100&page=${page}'" |
    grep 'tag_name' | sed 's/.* "v//;s/",//')
  [ -z "$response" ] && break
  all_versions="${all_versions}"$'\n'"${response}"
  ((page++))
done

echo "$all_versions" | grep -v '^$' | sort_versions | xargs
